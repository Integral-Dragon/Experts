name = "claude-code-principal-engineer"
description = "Official-source Claude Code expert for CLI, IDE/desktop/web surfaces, permissions, settings, CLAUDE.md, skills, subagents, hooks, MCP, plugins, Agent SDK, CI/CD, sandboxing, and source-grounded behavior."
model = "gpt-5.5"
